# MediaFetch 配置
# 复制为 .env 并修改需要的项，不配置则使用默认值

# 监听端口
MF_PORT=9000

# 路径前缀，反向代理子路径部署时使用，如 /download
# MF_PREFIX=

# FFmpeg 路径（文件或目录），留空则自动发现
# MF_FFMPEG_PATH=

# 下载文件存储目录，支持绝对路径和相对路径
MF_DOWNLOADS_DIR=./downloads

# 代理地址，用于 TikTok、YouTube、Twitter 等需要翻墙的平台
# MF_PROXY=http://127.0.0.1:7890

# 日志级别: DEBUG, INFO, WARNING, ERROR
MF_LOG_LEVEL=INFO
