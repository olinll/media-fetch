# MediaFetch 配置
# 复制为 .env 并修改需要的项，不配置则使用默认值

# 监听端口
MF_PORT=9000

# 路径前缀，反向代理子路径部署时使用，如 /download
# MF_PREFIX=

# FFmpeg 路径（文件或目录），留空则自动发现
# MF_FFMPEG_PATH=

# 下载文件存储目录，支持绝对路径和相对路径
MF_DOWNLOADS_DIR=./downloads

# API 访问密钥，留空则每次启动随机生成（控制台输出）
# MF_API_KEY=

# 信任的来源域名/URL，从此地址发起的请求免 API Key（逗号分隔，匹配 Origin/Referer 头）
# MF_TRUSTED_ORIGINS=http://localhost:9100,http://10.7.7.2:9100
